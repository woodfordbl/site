        "src/routes/**",
        "src/lib/schemas/page.ts",
        "src/lib/content/page-store.server.ts",
        "src/lib/content/page-head.ts",
        "src/hooks/use-local-pages.ts",
        "src/hooks/use-slug-page-resolution.ts"
      ],
      "docs": ["docs/architecture/pages.md"]
    },
    {
      "globs": [
        "src/hooks/use-inline-custom-block-keys.ts",
        "src/hooks/use-auto-focus.ts"
      ],
      "docs": ["docs/architecture/canvas-editor.md"]
    },
    {
