      "commands.ts",
      "effects.ts",
      "block.ts",
      "block-props.ts",
      "resolve-structural-action.ts",
      "structural-context.ts",
      "use-page-dispatch.ts",
      "use-canvas-row-actions.ts"
    ]
  },
  "mappings": [
    {
      "globs": ["src/lib/canvas/**", "src/components/canvas/**"],
      "docs": [
        "docs/architecture/canvas-editor.md",
        "docs/architecture/drag-and-drop.md",
        "docs/reference/canvas-commands.md"
      ],
      "majorGlobs": [
        "src/components/blocks/types/columns/**",
        "src/components/blocks/types/media/**",
